# Скопируй в .env.local для локальной разработки.
# В Vercel → Project Settings → Environment Variables те же ключи задаются как Encrypted.

# Telegram-бот для приёма заявок (создаётся через @BotFather)
TELEGRAM_BOT_TOKEN=

# Куда слать заявки. Узнаётся через @userinfobot
TELEGRAM_CHAT_ID=

# Public ID для виджета CloudPayments (его можно держать публичным)
NEXT_PUBLIC_CLOUDPAYMENTS_PUBLIC_ID=pk_f01283d698872ca60146adca52352
