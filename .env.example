# Скопируй в .env.local для локальной разработки.
# В Vercel → Project Settings → Environment Variables те же ключи задаются как Encrypted.
# Никогда не коммить .env.local в репозиторий.

# === Telegram (заявки с формы) ===
# Создаётся через @BotFather, серверный секрет.
TELEGRAM_BOT_TOKEN=
# Числовой chat_id, узнать через @userinfobot.
TELEGRAM_CHAT_ID=

# === CloudPayments ===
# Public ID — безопасно держать публичным, попадает в клиентский бандл.
NEXT_PUBLIC_CLOUDPAYMENTS_PUBLIC_ID=pk_f01283d698872ca60146adca52352
# API password — секрет для проверки HMAC-подписи на webhook. Только сервер.
CLOUDPAYMENTS_API_PASSWORD=

# === SMTP (письмо после оплаты) ===
EMAIL_FROM=info@honkvpn.com
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=587
SMTP_USERNAME=info@honkvpn.com
SMTP_PASSWORD=
